# Environment Variables

# Site URL (required for SEO, replace with production URL after deployment)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Formspree - Get your form endpoint from https://formspree.io
# Create a form, then add the endpoint here (e.g., https://formspree.io/f/xxxxxx)
NEXT_PUBLIC_FORMSPREE_ENDPOINT=
